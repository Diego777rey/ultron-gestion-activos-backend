# =============================================================
# Schema principal - Punto de entrada de Query y Mutation
# Los tipos se extienden desde los archivos .graphqls de cada módulo
# =============================================================

type Query {
    status: String

    # ---- Personas: Funcionarios ----
    listarFuncionarios: [FuncionarioOutput!]!
    listarFuncionariosPaginado(page: Int!, size: Int!, filter: String): FuncionarioPageResponse!
    buscarFuncionarioPorId(id: ID!): FuncionarioOutput

    # ---- Personas: Clientes ----
    listarClientes: [ClienteOutput!]!
    listarClientesPaginado(page: Int!, size: Int!): ClientePageResponse!
    buscarClientePorId(id: ID!): ClienteOutput

    # ---- Personas: Roles ----
    listarRoles: [RoleOutput!]!
    listarRolesPaginado(page: Int!, size: Int!): RolePageResponse!
    buscarRolePorId(id: ID!): RoleOutput
    rolesUsuarioPaginado(usuarioId: ID!, page: Int!, size: Int!, filter: String): RolePageResponse!
    rolesDisponiblesUsuarioPaginado(usuarioId: ID!, page: Int!, size: Int!, filter: String): RolePageResponse!

    # ---- Personas: Usuarios ----
    listarUsuarios: [UsuarioOutput!]!
    listarUsuariosPaginado(page: Int!, size: Int!): UsuarioPageResponse!
    buscarUsuarioPorId(id: ID!): UsuarioOutput
    
    # ---- Personas: Base ----
    buscarPersonaPorDocumento(documento: String!): PersonaOutput

    # ---- Patrimonio: Vehículos ----
    listarVehiculos: [VehiculoOutput!]!
    listarVehiculosPaginado(page: Int!, size: Int!): VehiculoPageResponse!
    listarVehiculosPorClientePaginado(idCliente: ID!, page: Int!, size: Int!): VehiculoPageResponse!
    buscarVehiculoPorId(id: ID!): VehiculoOutput
}

# Tipo base de Mutation - se extiende desde cada módulo
type Mutation {
    _empty: String
}
